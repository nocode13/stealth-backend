// Prisma schema — платформа продажи цветов (marketplace-ready)
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN // управляет справочником и продавцами
  SELLER // управляет своими листингами
  CUSTOMER // покупатель (мобилка)
}

enum SellerStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum ListingStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

// Статус ревью для категорий/позиций каталога, предложенных продавцом.
// SUPER_ADMIN создаёт сразу APPROVED; SELLER — уходит в PENDING до апрува.
enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

// Жизненный цикл заказа. Переходы валидируются в OrdersService.ALLOWED_TRANSITIONS —
// эта же карта строит кнопки в кабинете продавца в боте, чтобы список не разъезжался.
enum OrderStatus {
  NEW // создан, продавец ещё не подтвердил
  CONFIRMED // продавец принял
  ASSEMBLING // собирается
  DELIVERING // передан курьеру, едет
  ARRIVED // курьер на месте — покупателю уходит пуш «выходите, заказ у двери»
  DELIVERED // доставлен (терминальный)
  CANCELLED // отменён (терминальный)
}

// Пока единственный способ оплаты. Payme/Click добавляются значениями этого енама —
// отдельная однострочная миграция, схема заказа при этом не меняется.
enum PaymentMethod {
  CASH
}

enum PaymentStatus {
  PENDING
  PAID
  REFUNDED
}

// Зачем открывали бота по диплинку. Оба флоу устроены одинаково (nonce → бот → поллинг),
// поэтому живут в одной таблице BotLinkSession, а не в двух почти одинаковых.
enum BotSessionPurpose {
  DELIVERY_LOCATION // покупатель шлёт геолокацию для адреса доставки
  SELLER_LINK // продавец привязывает свой Telegram к аккаунту админки
}

model User {
  id           String   @id @default(cuid())
  // telegramId — якорь личности мобилки: вход только через Telegram-бота.
  telegramId   String?  @unique
  // phone/email/name — опциональные профильные поля, юзер дозаполняет их сам.
  // В профиле они так и остаются опциональными, но checkout требует телефон и имя:
  // они уходят в снапшот заказа (Order.contactPhone/contactName), а телефон,
  // если его ещё не было, дописывается сюда.
  phone        String?  @unique
  email        String?  @unique
  name         String?
  // passwordHash опционален: он есть только у админов (вход по паролю в админку).
  passwordHash String?
  role         Role     @default(CUSTOMER)
  // Продавец, к которому привязан пользователь (для роли SELLER).
  sellerId     String?
  seller       Seller?  @relation("SellerMembers", fields: [sellerId], references: [id], onDelete: SetNull)
  // Продавец, которым владеет пользователь (owner). Обратная сторона Seller.owner.
  ownedSeller  Seller?  @relation("SellerOwner")
  refreshTokens RefreshToken[]
  cartItems    CartItem[]
  orders       Order[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

// Короткоживущая сессия входа через Telegram-бота (deeplink + polling).
// Мобилка создаёт строку и открывает t.me/<bot>?start=<nonce>; бот на /start
// проставляет telegramId/userId; мобилка поллит и забирает токены ровно один раз.
// Токены здесь НЕ хранятся — при консьюме выпускается свежая пара (issueTokens).
model TelegramAuthSession {
  id         String    @id @default(cuid())
  nonce      String    @unique
  telegramId String? // проставляется ботом на /start
  userId     String? // юзер, найденный/созданный по telegramId
  consumedAt DateTime? // токены уже забраны — повторно не выдаём
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  @@index([expiresAt])
  @@map("telegram_auth_sessions")
}

// Короткоживущая сессия «сходить в бота и вернуться» — та же механика, что у
// TelegramAuthSession (nonce в диплинке + поллинг), но для уже известного пользователя:
// userId берётся из текущей авторизации, а не создаётся ботом.
// TelegramAuthSession намеренно оставлена отдельной моделью: она выдаёт токены и
// консьюмится иначе, объединять их значило бы усложнить вход ради экономии таблицы.
model BotLinkSession {
  id      String            @id @default(cuid())
  nonce   String            @unique
  purpose BotSessionPurpose
  userId  String

  // Заполняются ботом, когда покупатель прислал геопозицию (purpose DELIVERY_LOCATION).
  latitude  Float?
  longitude Float?

  consumedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("bot_link_sessions")
}

// Хранит хэш активного refresh-токена мобильной сессии (ротация при обновлении).
model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String // sha256 от refresh-токена
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Seller {
  id          String       @id @default(cuid())
  name        String
  description String?
  bannerUrl   String?
  status      SellerStatus @default(ACTIVE)
  ownerUserId String       @unique
  owner       User         @relation("SellerOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  members     User[]       @relation("SellerMembers")
  listings    Listing[]
  categories    Category[]
  catalogItems  CatalogItem[]
  orders        Order[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([createdAt])
  @@index([status])
  @@map("sellers")
}

// Категории каталога: master (sellerId = null, создаёт SUPER_ADMIN, сразу APPROVED)
// и кастомные, предложенные продавцом (sellerId заполнен, уходят в PENDING до апрува
// SUPER_ADMIN'ом и видны/доступны для использования только этому продавцу).
model Category {
  id           String       @id @default(cuid())
  nameRu       String
  nameUz       String?
  nameEn       String?
  nameKaa      String?
  sellerId     String?
  seller       Seller?      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  status       ReviewStatus @default(APPROVED)
  catalogItems CatalogItem[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
  @@map("categories")
}

// Справочник цветов — master-список (sellerId = null, создаёт SUPER_ADMIN) плюс
// кастомные позиции, предложенные продавцом (тот же паттерн ревью, что и Category).
model CatalogItem {
  id          String       @id @default(cuid())
  name        String
  slug        String
  categoryId  String
  category    Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  description String?
  imageUrl    String?
  unit        String       @default("шт") // единица измерения: шт, букет, упаковка...
  sellerId    String?
  seller      Seller?      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  status      ReviewStatus @default(APPROVED)
  listings    Listing[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([sellerId, slug])
  @@index([sellerId])
  @@index([status])
  @@index([categoryId])
  @@index([createdAt])
  @@map("catalog")
}

// Предложение продавца поверх позиции справочника + инвентарь (остаток).
model Listing {
  id            String        @id @default(cuid())
  sellerId      String
  seller        Seller        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  catalogItemId String
  catalogItem   CatalogItem   @relation(fields: [catalogItemId], references: [id], onDelete: Restrict)
  price         Decimal       @db.Decimal(12, 2)
  currency      String        @default("UZS")
  stock         Int           @default(0)
  status        ListingStatus @default(DRAFT)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  cartItems     CartItem[]
  orderItems    OrderItem[]

  @@unique([sellerId, catalogItemId])
  @@index([status])
  @@index([catalogItemId])
  @@index([createdAt])
  @@map("listings")
}

// Позиция в корзине покупателя. Отдельной обёртки Cart нет — у пользователя
// неявно одна корзина, как RefreshToken висит прямо на User без "Session".
model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
  @@map("cart_items")
}

// Заказ — всегда на ОДНОГО продавца: один checkout с товарами разных продавцов
// режется на несколько Order с общим groupId. Отдельной модели Checkout нет по той же
// причине, что нет обёртки Cart над CartItem — сущность без собственных полей не нужна.
//
// Все деньги и контакты — снапшот на момент оформления: цена листинга и профиль
// пользователя меняются, а заказ обязан остаться читаемым как есть.
model Order {
  id       String @id @default(cuid())
  // Общий ключ заказов одного оформления (несколько продавцов = несколько Order).
  groupId  String
  // Человекочитаемый номер для поддержки и для поиска в боте.
  orderNumber Int @unique @default(autoincrement())

  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Restrict)
  sellerId String
  seller   Seller @relation(fields: [sellerId], references: [id], onDelete: Restrict)

  status        OrderStatus   @default(NEW)
  paymentMethod PaymentMethod @default(CASH)
  paymentStatus PaymentStatus @default(PENDING)

  itemsTotal  Decimal @db.Decimal(12, 2)
  deliveryFee Decimal @default(0) @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)
  currency    String  @default("UZS")

  contactName  String
  contactPhone String

  deliveryAddress String
  deliveryComment String?
  // Координаты из Telegram-локации. Необязательны: текстового адреса достаточно,
  // но именно они дают курьеру кнопку «Маршрут» в карточке локации.
  deliveryLat     Float?
  deliveryLng     Float?

  // Задел под курьерскую систему: позже заменяется на courierId → модель Courier.
  courierName  String?
  courierPhone String?

  cancelReason String?

  items   OrderItem[]
  history OrderStatusHistory[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  confirmedAt DateTime?
  deliveredAt DateTime?

  @@index([groupId])
  @@index([sellerId, status])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("orders")
}

// Позиция заказа — полный снапшот, а не только FK на листинг: цена и название меняются,
// листинг может уехать в ARCHIVED или быть удалён (тогда listingId станет null).
model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  listingId String?
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)

  catalogItemName     String
  catalogItemImageUrl String?
  unit                String  @default("шт")

  price    Decimal @db.Decimal(12, 2)
  quantity Int
  total    Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@index([orderId])
  @@map("order_items")
}

// Лог смен статуса: по нему строится таймлайн заказа в мобилке и в админке.
// changedByUserId пуст, когда статус проставила система (создание заказа).
model OrderStatusHistory {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  status          OrderStatus
  comment         String?
  changedByUserId String?

  createdAt DateTime @default(now())

  @@index([orderId])
  @@map("order_status_history")
}
