// Prisma schema — платформа продажи цветов (marketplace-ready)
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN // управляет справочником и продавцами
  SELLER // управляет своими листингами
  CUSTOMER // покупатель (мобилка)
}

enum SellerStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum ListingStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

// Статус ревью для категорий/позиций каталога, предложенных продавцом.
// SUPER_ADMIN создаёт сразу APPROVED; SELLER — уходит в PENDING до апрува.
enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String   @id @default(cuid())
  // telegramId — якорь личности мобилки: вход только через Telegram-бота.
  telegramId   String?  @unique
  // phone/email/name — опциональные профильные поля, юзер дозаполняет их сам.
  // Станут обязательными на этапе оформления заказов (модели Order пока нет).
  phone        String?  @unique
  email        String?  @unique
  name         String?
  // passwordHash опционален: он есть только у админов (вход по паролю в админку).
  passwordHash String?
  role         Role     @default(CUSTOMER)
  // Продавец, к которому привязан пользователь (для роли SELLER).
  sellerId     String?
  seller       Seller?  @relation("SellerMembers", fields: [sellerId], references: [id], onDelete: SetNull)
  // Продавец, которым владеет пользователь (owner). Обратная сторона Seller.owner.
  ownedSeller  Seller?  @relation("SellerOwner")
  refreshTokens RefreshToken[]
  cartItems    CartItem[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

// Короткоживущая сессия входа через Telegram-бота (deeplink + polling).
// Мобилка создаёт строку и открывает t.me/<bot>?start=<nonce>; бот на /start
// проставляет telegramId/userId; мобилка поллит и забирает токены ровно один раз.
// Токены здесь НЕ хранятся — при консьюме выпускается свежая пара (issueTokens).
model TelegramAuthSession {
  id         String    @id @default(cuid())
  nonce      String    @unique
  telegramId String? // проставляется ботом на /start
  userId     String? // юзер, найденный/созданный по telegramId
  consumedAt DateTime? // токены уже забраны — повторно не выдаём
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  @@index([expiresAt])
  @@map("telegram_auth_sessions")
}

// Хранит хэш активного refresh-токена мобильной сессии (ротация при обновлении).
model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String // sha256 от refresh-токена
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Seller {
  id          String       @id @default(cuid())
  name        String
  status      SellerStatus @default(ACTIVE)
  ownerUserId String       @unique
  owner       User         @relation("SellerOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  members     User[]       @relation("SellerMembers")
  listings    Listing[]
  categories    Category[]
  catalogItems  CatalogItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([createdAt])
  @@index([status])
  @@map("sellers")
}

// Категории каталога: master (sellerId = null, создаёт SUPER_ADMIN, сразу APPROVED)
// и кастомные, предложенные продавцом (sellerId заполнен, уходят в PENDING до апрува
// SUPER_ADMIN'ом и видны/доступны для использования только этому продавцу).
model Category {
  id           String       @id @default(cuid())
  nameRu       String
  nameUz       String?
  nameEn       String?
  nameKaa      String?
  sellerId     String?
  seller       Seller?      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  status       ReviewStatus @default(APPROVED)
  catalogItems CatalogItem[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
  @@map("categories")
}

// Справочник цветов — master-список (sellerId = null, создаёт SUPER_ADMIN) плюс
// кастомные позиции, предложенные продавцом (тот же паттерн ревью, что и Category).
model CatalogItem {
  id          String       @id @default(cuid())
  name        String
  slug        String
  categoryId  String
  category    Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  description String?
  imageUrl    String?
  unit        String       @default("шт") // единица измерения: шт, букет, упаковка...
  sellerId    String?
  seller      Seller?      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  status      ReviewStatus @default(APPROVED)
  listings    Listing[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([sellerId, slug])
  @@index([sellerId])
  @@index([status])
  @@index([categoryId])
  @@index([createdAt])
  @@map("catalog")
}

// Предложение продавца поверх позиции справочника + инвентарь (остаток).
model Listing {
  id            String        @id @default(cuid())
  sellerId      String
  seller        Seller        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  catalogItemId String
  catalogItem   CatalogItem   @relation(fields: [catalogItemId], references: [id], onDelete: Restrict)
  price         Decimal       @db.Decimal(12, 2)
  currency      String        @default("UZS")
  stock         Int           @default(0)
  status        ListingStatus @default(DRAFT)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  cartItems     CartItem[]

  @@unique([sellerId, catalogItemId])
  @@index([status])
  @@index([catalogItemId])
  @@index([createdAt])
  @@map("listings")
}

// Позиция в корзине покупателя. Отдельной обёртки Cart нет — у пользователя
// неявно одна корзина, как RefreshToken висит прямо на User без "Session".
model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
  @@map("cart_items")
}
