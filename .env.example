# App
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:19006

# Database (matches docker-compose.yml)
DATABASE_URL="postgresql://stealth:stealth@localhost:5432/stealth?schema=public"

# JWT (mobile)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# Session (admin, httpOnly cookie)
SESSION_SECRET=change-me-session-secret

# OTP (mobile, phone-first passwordless)
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# Email OTP (Gmail SMTP). Пусто в dev → код падает в лог (фолбэк).
# SMTP_PASS — app password Gmail, не обычный пароль.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
OTP_MAIL_FROM="Stealth <no-reply@stealth.local>"

# Telegram OTP (бот подключается позже; пусто → заглушка пишет код в лог)
TELEGRAM_BOT_TOKEN=

# SMS OTP (провайдер подключается позже; пусто → заглушка пишет код в лог)
SMS_PROVIDER=
SMS_API_KEY=
