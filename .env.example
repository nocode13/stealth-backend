# App
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:19006
# Публичный адрес админки: из него бот строит ссылку «Открыть в админке».
ADMIN_URL=http://localhost:5173

# Database (matches docker-compose.yml)
DATABASE_URL="postgresql://stealth:stealth@localhost:5432/stealth?schema=public"

# JWT (mobile)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# Session (admin, httpOnly cookie)
SESSION_SECRET=change-me-session-secret

# Пароль супер-админа из сида. На проде задать сильный, локально можно не ставить.
SEED_ADMIN_PASSWORD=

# S3-совместимое хранилище фото каталога (локально — MinIO из docker-compose,
# на проде — Cloudflare R2: S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com,
# S3_REGION=auto, S3_PUBLIC_URL=публичный домен бакета (pub-xxx.r2.dev или свой)).
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=catalog
S3_ACCESS_KEY=stealth
S3_SECRET_KEY=stealth123
# Указывает на КОНКРЕТНЫЙ бакет — имя бакета входит в значение (для MinIO это
# endpoint + /catalog). Код склеивает ссылку как ${S3_PUBLIC_URL}/${key}.
S3_PUBLIC_URL=http://localhost:9000/catalog

# Telegram — единственный вход в мобилку (бот + Mini App).
# Пусто → приложение поднимается, бот не стартует (warning в лог).
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# false → long-polling (dev, без публичного URL). true → webhook по TELEGRAM_WEBHOOK_URL.
TELEGRAM_USE_WEBHOOK=false
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
# TTL сессии входа по nonce (deeplink t.me/<bot>?start=<nonce> + polling).
TG_AUTH_SESSION_TTL_SECONDS=180
